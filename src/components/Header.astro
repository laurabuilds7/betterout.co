---
const links = [
  { href: "/guides/", label: "The Library" },
  { href: "/about/", label: "Atelier" },
];
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<header class="sticky top-0 z-30 backdrop-blur-md bg-bone/85 border-b border-espresso/10">
  <div class="max-w-7xl mx-auto px-6 sm:px-10 py-5 grid grid-cols-3 items-center gap-6">
    <div class="hidden sm:block label-wide text-espresso/55">
      Cape Town · MMXXVI
    </div>

    <a href="/" class="text-center text-espresso leading-none col-span-2 sm:col-span-1 sm:text-center sm:mx-auto" aria-label="Better Out Co. — home">
      <span class="display text-2xl sm:text-[1.65rem] tracking-wider">
        better<span class="display-italic text-sage">·</span>out
      </span>
      <div class="label-wide text-espresso/50 mt-1 text-[0.55rem]">Coffee · Cape Town</div>
    </a>

    <nav class="hidden sm:flex items-center justify-end gap-8">
      {links.map((l) => {
        const normalized = l.href.replace(/\/$/, "") || "/";
        const active = normalized === pathname || (normalized !== "/" && pathname.startsWith(normalized));
        return (
          <a href={l.href} class={`label ${active ? "text-espresso" : "text-espresso/55 hover:text-espresso"} transition-colors`}>
            {l.label}
          </a>
        );
      })}
    </nav>

    <nav class="flex sm:hidden col-span-3 items-center justify-center gap-7 pt-2 -mb-1">
      {links.map((l) => (
        <a href={l.href} class="label text-espresso/65 hover:text-espresso transition-colors">{l.label}</a>
      ))}
    </nav>
  </div>
</header>
