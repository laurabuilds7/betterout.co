---
const links = [
  { href: "/guides/", label: "Guides" },
  { href: "/about/", label: "About" },
];
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<header class="sticky top-0 z-30 backdrop-blur-md bg-cream/85 border-b border-coffee/10">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between">
    <a href="/" class="display text-xl sm:text-2xl text-coffee leading-none">
      better out<span class="text-kraft">.</span>
    </a>
    <nav class="flex items-center gap-5 sm:gap-7">
      {links.map((l) => {
        const normalized = l.href.replace(/\/$/, "") || "/";
        const active = normalized === pathname || (normalized !== "/" && pathname.startsWith(normalized));
        return (
          <a href={l.href} class={`label ${active ? "text-coffee" : "text-coffee/55 hover:text-coffee"} transition-colors`}>
            {l.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
