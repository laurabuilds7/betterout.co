---
interface Props {
  title: string;
  subtitle: string;
  pages: number;
  pdf: string;
  slug: string;
  level: string;
  tone?: "sagelight" | "sage" | "moss" | "sand" | "nude" | "brown";
  comingSoon?: boolean;
}
const { title, subtitle, pages, pdf, slug, level, tone = "sagelight", comingSoon = false } = Astro.props;
const dark = tone === "moss" || tone === "brown";
---
<article class={`guide-card tone-${tone} group p-7 sm:p-8 flex flex-col break-inside-avoid mb-5`}>
  <div class="flex items-center justify-between gap-4 mb-6">
    <span class={`label ${dark ? "text-cream/85" : "text-matcha"}`}>{level}</span>
    <span class={`label-wide text-[0.6rem] ${dark ? "text-cream/45" : "text-forest/40"}`}>
      {comingSoon ? "Coming soon" : `${pages} pp · pdf`}
    </span>
  </div>

  <h3 class={`display text-3xl sm:text-[2.1rem] leading-[1.0] mb-4 ${dark ? "text-cream" : "text-forest"}`}>
    <a href={`/guides/${slug}/`} class={`transition-colors ${dark ? "hover:text-cream/80" : "hover:text-matcha"}`}>{title}</a>
  </h3>

  <p class={`prose-body text-base leading-snug mb-7 ${dark ? "text-cream/85" : "text-espresso/70"}`}>
    {subtitle}
  </p>

  <div class="flex flex-wrap items-center gap-4 pt-1">
    {comingSoon ? (
      <span class={`text-sm inline-flex items-center gap-2 ${dark ? "text-cream/70" : "text-forest/55"} label`}>
        Full guide coming soon
      </span>
    ) : (
      <>
        <a href={pdf} download data-guide-download class={`text-sm ${dark ? "btn-outline-cream" : "btn-outline"}`} style="padding: 0.7rem 1.4rem;">
          Free PDF
          <svg width="12" height="12" aria-hidden="true"><use href="#arrow-down"/></svg>
        </a>
        <a href={`/guides/${slug}/`} class={dark ? "label text-cream/80 hover:text-cream transition-colors" : "link-quiet"}>Read about it</a>
      </>
    )}
  </div>
</article>
