---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "Better Out Co.",
  description = "The first mould-free, lab-tested coffee enema in South Africa. A bold, clean ritual for energy, vitality and living well from the inside out.",
  noindex = false,
} = Astro.props;

const fullTitle = title === "Better Out Co." ? title : `${title} — Better Out Co.`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="color-scheme" content="light" />
  <meta name="theme-color" content="#3C2B1D" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonical} />

  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%233C2B1D'/%3E%3Ctext y='23' x='16' font-size='20' font-family='Georgia,serif' font-style='italic' fill='%2384956F' text-anchor='middle'%3Eb%3C/text%3E%3C/svg%3E" />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Better Out Co." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex flex-col">
  <!-- shared SVG defs: a single thin botanical sprig -->
  <svg width="0" height="0" aria-hidden="true" style="position:absolute">
    <defs>
      <symbol id="sprig" viewBox="0 0 60 120">
        <path d="M30 4 L30 116" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M30 22 Q 18 26 14 38" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M30 38 Q 42 42 46 54" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M30 56 Q 18 60 14 72" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M30 74 Q 42 78 46 90" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <ellipse cx="13" cy="38" rx="5" ry="2.2" transform="rotate(-22 13 38)" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <ellipse cx="47" cy="54" rx="5" ry="2.2" transform="rotate(22 47 54)" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <ellipse cx="13" cy="72" rx="5" ry="2.2" transform="rotate(-22 13 72)" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <ellipse cx="47" cy="90" rx="5" ry="2.2" transform="rotate(22 47 90)" stroke="currentColor" stroke-width="0.7" fill="none"/>
      </symbol>
      <symbol id="diamond-ornament" viewBox="0 0 120 8">
        <line x1="0" y1="4" x2="55" y2="4" stroke="currentColor" stroke-width="0.6"/>
        <line x1="65" y1="4" x2="120" y2="4" stroke="currentColor" stroke-width="0.6"/>
        <rect x="57" y="1" width="6" height="6" transform="rotate(45 60 4)" fill="#84956F"/>
      </symbol>
      <symbol id="arrow-down" viewBox="0 0 24 24">
        <path d="M12 3 V20 M5 13 L12 20 L19 13" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>
      <symbol id="arrow-right" viewBox="0 0 24 24">
        <path d="M3 12 H20 M13 5 L20 12 L13 19" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>
    </defs>
  </svg>

  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />

  <!-- Soft Instagram nudge — appears after a guide download starts. Not a gate. -->
  <aside id="ig-nudge" class="ig-nudge" hidden role="status" aria-live="polite">
    <button type="button" class="ig-nudge__close" aria-label="Dismiss" data-ig-close>&times;</button>
    <div class="label-wide text-matcha mb-2">Your guide is downloading</div>
    <p class="font-serif italic text-espresso/75 text-base leading-snug mb-5">
      Follow along on Instagram for new rituals, recipes and quiet notes.
    </p>
    <a href="https://www.instagram.com/better.out.co" target="_blank" rel="noopener" class="btn-bright ig-nudge__cta">
      Follow @better.out.co
    </a>
  </aside>

  <script is:inline>
    (function () {
      var nudge = document.getElementById("ig-nudge");
      if (!nudge) return;
      var hideTimer = null;

      function show() {
        nudge.hidden = false;
        requestAnimationFrame(function () { nudge.classList.add("is-visible"); });
        if (hideTimer) clearTimeout(hideTimer);
        hideTimer = setTimeout(hide, 14000);
      }
      function hide() {
        nudge.classList.remove("is-visible");
        setTimeout(function () { nudge.hidden = true; }, 320);
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      }

      // Don't intercept the download — just show the nudge shortly after the click.
      document.addEventListener("click", function (e) {
        if (!e.target.closest("[data-guide-download]")) return;
        setTimeout(show, 400);
      });
      nudge.querySelectorAll("[data-ig-close]").forEach(function (b) {
        b.addEventListener("click", hide);
      });
    })();
  </script>
</body>
</html>
