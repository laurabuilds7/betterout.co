---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import GuideCard from "../components/GuideCard.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order
);
const totalPages = guides.reduce((n, g) => n + g.data.pages, 0);

// Pinterest earthy palette — sage & moss greens, sand & nude browns
const toneBySlug: Record<string, "sagelight" | "sage" | "moss" | "sand" | "nude" | "brown"> = {
  "the-method": "brown",            // coffee brown — the flagship how-to
  "kitchen-apothecary": "moss",     // deep moss green — the herb one
  "low-tox-living": "sage",         // dusty sage
  "steady": "sand",                 // warm sand
  "nourished-littles": "sagelight", // soft sage
  "roots": "nude",                  // nude brown
};
---
<Base>

  <!-- ───────── HERO ───────── -->
  <section class="relative overflow-hidden" style="background-color:#EDF1E6;">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 pt-24 sm:pt-28 pb-20 sm:pb-28 text-center">
      <div class="label-wide text-matcha mb-8 fade-up">
        Mould-free · Lab-tested · Cape Town
      </div>

      <h1 class="display text-cocoa text-[3.4rem] sm:text-7xl md:text-[6.5rem] fade-up-2">
        Better out<br/>
        <span class="display-italic text-sage">than in.</span>
      </h1>

      <p class="mt-10 lede max-w-2xl mx-auto fade-up-3">
        The first mould-free, lab-tested coffee enema in South Africa —
        a clean, energising ritual for people who want to feel <span class="text-matcha-deep font-semibold">lighter, clearer and more alive.</span>
      </p>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-5 fade-up-4">
        <a href="#ritual" class="btn-bright">Discover the ritual</a>
        <a href="https://instagram.com/better.out.co" rel="me noopener" target="_blank" class="link-quiet">Follow @better.out.co</a>
      </div>
    </div>
  </section>

  <!-- ───────── 01 — THE RITUAL ───────── -->
  <section id="ritual" class="relative border-t border-espresso/10" style="background-color:#F1EBDC;">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 py-24 sm:py-32">
      <div class="flex items-center justify-center gap-4 mb-16">
        <span class="numeral text-matcha text-2xl">01</span>
        <span class="label-wide text-forest/60">The Ritual</span>
      </div>

      <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-start">
        <div class="md:col-span-5">
          <h2 class="display text-forest text-4xl sm:text-5xl md:text-[3.4rem]">
            A clean, <span class="text-matcha">high-performance</span> reset — the original inner biohack.
          </h2>
        </div>

        <div class="md:col-span-6 md:col-start-7 prose-body text-espresso/85 space-y-5">
          <p>
            High-potency, mould-free <span class="text-sage-deep font-medium">raw low-roast</span> green coffee — brewed gently and used as a bottom-up flush, not a drink. A simple daily ritual for energy, clarity and feeling lighter.
          </p>
          <p>
            Athletes, high performers and the biohacking crowd have leaned on it for years — for clean energy, sharper focus and a lighter body. Nothing extreme, nothing faddy. But until now, it simply didn't exist in South Africa — not clean, not lab-tested, not mould-free. <span class="text-sage-deep font-medium">Now it's finally here.</span>
          </p>

          <ul class="pt-3 space-y-3.5 label text-forest/70">
            <li class="flex items-center gap-4"><span class="diamond"></span> Single-origin green coffee</li>
            <li class="flex items-center gap-4"><span class="diamond"></span> Raw · low-roast · high potency</li>
            <li class="flex items-center gap-4"><span class="diamond"></span> Independently lab-tested · mould-free</li>
            <li class="flex items-center gap-4"><span class="diamond"></span> Made in Cape Town, by hand</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────── PULL QUOTE ───────── -->
  <section class="relative border-t border-espresso/10" style="background-color:#BFC8AA;">
    <div class="max-w-4xl mx-auto px-6 sm:px-10 py-24 sm:py-32 text-center">
      <div class="rule-centre text-cocoa/30 mb-10">
        <svg width="120" height="8" aria-hidden="true"><use href="#diamond-ornament"/></svg>
      </div>

      <blockquote class="pull-quote">
        Tired, foggy, inflamed — we've been told that's just normal. It isn't. So I built the cleanest, most powerful reset I could — the first South Africa has ever had.
      </blockquote>

      <div class="mt-8 label-wide text-matcha">
        Laura Weyel — Founder
      </div>
    </div>
  </section>

  <!-- ───────── 02 — THE PRODUCT ───────── -->
  <section class="relative bg-forest text-bone overflow-hidden">
    <div class="max-w-4xl mx-auto px-6 sm:px-10 py-24 sm:py-32 text-center relative">
      <div class="flex items-center justify-center gap-4 mb-8">
        <span class="numeral text-bright text-2xl">02</span>
        <span class="label-wide text-bone/55">The Product</span>
      </div>

      <h2 class="display text-4xl sm:text-6xl md:text-[5rem] mb-5">
        The coffee.<br/>
        The kit.<br/>
        <span class="text-bright">Available now.</span>
      </h2>

      <p class="lede text-bone/80 max-w-lg mx-auto mb-7">
        High-potency, mould-free green coffee + a clean, well-made kit. The first South Africa's ever had.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-5">
        <a href="https://wa.me/27630804439?text=Hi%20Laura%2C%20I%27d%20like%20to%20order%20Better%20Out%20Co.%20green%20coffee%20%F0%9F%8C%BF" rel="noopener" target="_blank" class="btn-bone">
          Order on WhatsApp
        </a>
        <a href="https://instagram.com/better.out.co" rel="me noopener" target="_blank" class="link-quiet" style="color: var(--color-bright);">
          @better.out.co
        </a>
      </div>
    </div>
  </section>

  <!-- ───────── 03 — FREE GUIDES (secondary, at the bottom) ───────── -->
  <section id="guides" class="relative border-t border-espresso/10">
    <div class="max-w-6xl mx-auto px-6 sm:px-10 py-24 sm:py-32">

      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="flex items-center justify-center gap-4 mb-7">
          <span class="numeral text-matcha text-2xl">03</span>
          <span class="label-wide text-forest/60">Free Guides</span>
        </div>
        <h2 class="display text-forest text-4xl sm:text-5xl md:text-[3.4rem] mb-6">
          Better <span class="text-matcha">starts now.</span>
        </h2>
        <p class="lede">
          12+ years as a nutritionist — and everything I know is in these pages. Steady energy, food as medicine, a lighter toxic load, thriving kids, healing at the root. <span class="text-matcha-deep font-medium">{totalPages}+ pages, completely free.</span> Pick one and feel the difference.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 items-stretch">
        {guides.map((g) => (
          <GuideCard
            title={g.data.title}
            subtitle={g.data.subtitle}
            pages={g.data.pages}
            pdf={g.data.pdf}
            slug={g.data.slug}
            level={g.data.level}
            tone={toneBySlug[g.data.slug] ?? "sagelight"}
            comingSoon={g.data.comingSoon}
          />
        ))}
      </div>

      <div class="mt-14 flex justify-center">
        <a href="/guides/" class="link-quiet">See all guides</a>
      </div>
    </div>
  </section>

</Base>
