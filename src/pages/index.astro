---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import GuideCard from "../components/GuideCard.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = guides.find((g) => g.data.slug === "steady")!;
const rest = guides.filter((g) => g.data.slug !== "steady");
const totalPages = guides.reduce((n, g) => n + g.data.pages, 0);
---
<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-cream-deep/40 via-cream to-cream"></div>
    <div class="max-w-5xl mx-auto px-5 sm:px-8 pt-16 sm:pt-24 pb-12 sm:pb-16">
      <div class="flex flex-wrap items-center gap-3 mb-7">
        <span class="label inline-flex items-center px-3 py-1.5 rounded-full bg-coffee text-cream">! Not for drinking !</span>
        <span class="label text-coffee/55">Cape Town · Est. 2026</span>
      </div>

      <h1 class="display text-5xl sm:text-7xl md:text-8xl text-coffee leading-[0.95]">
        Yes, it's coffee.<br/>
        <span class="text-kraft">It just goes elsewhere.</span>
      </h1>

      <p class="mt-8 max-w-2xl prose-body italic text-coffee/80">
        A liver-loving, cell-cleansing ritual for people who take their biohacking seriously — and a quiet library of guides on eating well, lightening your load, and healing at the root.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="#library" class="btn-coffee">Read the free library</a>
        <a href="/about/" class="btn-outline">About Better Out Co.</a>
      </div>

      <p class="mt-7 label text-coffee/45">First mould-free · Lab-tested · Coffee in bags + enema kit · Coming soon</p>
    </div>
  </section>

  <!-- The reframe -->
  <section class="border-y border-coffee/10 bg-cream-soft/40">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 py-14 sm:py-20 grid md:grid-cols-2 gap-10 md:gap-16 items-start">
      <div>
        <div class="label text-kraft mb-4">What is a coffee enema?</div>
        <h2 class="display text-3xl sm:text-4xl text-coffee leading-tight mb-5">
          A gentle, bottom-up flush — used since the 1920s.
        </h2>
      </div>
      <div class="prose-body text-coffee/85 space-y-4">
        <p>
          Organic, mould-free coffee, brewed gently — not to drink — to stimulate the liver's main detox pathway. The caffeine is absorbed through the colon wall, signalling the liver to dump bile loaded with what doesn't belong.
        </p>
        <p>
          Loved today by biohackers, athletes, and anyone serious about feeling clear, light, and well. Not magic, not extreme. Just one of the oldest tools in integrative wellness, made properly for the first time in South Africa.
        </p>
      </div>
    </div>
  </section>

  <!-- Library -->
  <section id="library" class="max-w-6xl mx-auto px-5 sm:px-8 py-16 sm:py-24">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
      <div class="max-w-2xl">
        <div class="label text-kraft mb-3">The library — free, always</div>
        <h2 class="display text-4xl sm:text-5xl text-coffee leading-[1.05] mb-5">
          Five little guides on living well from the inside out.
        </h2>
        <p class="prose-body text-coffee/75">
          {totalPages} pages of plain-language, anti-hype wellness — written from Laura's kitchen in Cape Town. Start anywhere. Most readers begin with <a href="/guides/steady/" class="underline decoration-kraft underline-offset-4 hover:text-coffee">Steady</a>.
        </p>
      </div>
    </div>

    <!-- Featured: Steady -->
    <div class="mb-7">
      <GuideCard
        title={featured.data.title}
        subtitle={featured.data.subtitle}
        pages={featured.data.pages}
        pdf={featured.data.pdf}
        slug={featured.data.slug}
        level={featured.data.level}
        excerpt={featured.data.excerpt}
        variant="feature"
      />
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {rest.map((g) => (
        <GuideCard
          title={g.data.title}
          subtitle={g.data.subtitle}
          pages={g.data.pages}
          pdf={g.data.pdf}
          slug={g.data.slug}
          level={g.data.level}
        />
      ))}
    </div>
  </section>

  <!-- Product teaser -->
  <section class="bg-coffee text-cream">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 py-16 sm:py-20 text-center">
      <div class="label text-cream-soft mb-5">Better Out Co. — the product</div>
      <h2 class="display text-4xl sm:text-5xl md:text-6xl leading-[1.05] mb-6">
        Coffee in bags. Enema kit. Coming soon.
      </h2>
      <p class="prose-body italic text-cream/85 max-w-2xl mx-auto mb-9">
        Lab-tested, guaranteed mould-free organic coffee, paired with a clean, well-made enema kit. The first of its kind in South Africa. Be the first to know — message us on Instagram.
      </p>
      <a href="https://instagram.com/better.out.co" rel="me noopener" class="inline-flex items-center gap-2 bg-cream text-coffee font-sans font-semibold text-sm uppercase tracking-wider px-7 py-3.5 rounded-full hover:bg-cream-soft transition-colors">
        @better.out.co
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>
  </section>
</Base>
