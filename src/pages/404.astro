---
import Base from "../layouts/Base.astro";
---
<Base title="Not found" noindex>
  <section class="max-w-2xl mx-auto px-5 sm:px-8 py-24 text-center">
    <div class="label text-kraft mb-5">404</div>
    <h1 class="display text-5xl sm:text-6xl text-coffee mb-6 leading-[1.02]">
      Nothing in this corner.
    </h1>
    <p class="prose-body italic text-coffee/75 mb-9">
      The page you were looking for has gone elsewhere. The library is still right here.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-coffee">Home</a>
      <a href="/guides/" class="btn-outline">The library</a>
    </div>
  </section>
</Base>
