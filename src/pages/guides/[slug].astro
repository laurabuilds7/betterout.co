---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((g) => ({ params: { slug: g.data.slug }, props: { guide: g } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const all = (await getCollection("guides")).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((g) => g.data.slug === guide.data.slug);
const next = all[(idx + 1) % all.length];
const roman = ["I","II","III","IV","V","VI","VII","VIII","IX","X"];
const num = roman[guide.data.order - 1] ?? String(guide.data.order);
---
<Base title={guide.data.title} description={guide.data.subtitle}>

  <section class="max-w-3xl mx-auto px-6 sm:px-10 pt-16 sm:pt-20 pb-12">
    <a href="/guides/" class="label text-espresso/55 hover:text-espresso transition-colors inline-flex items-center gap-3 mb-14">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      The Library
    </a>

    <div class="text-center mb-10">
      <div class="label-wide text-espresso/55 mb-6">
        <span class="numeral text-sage text-lg mr-3">{num}</span>
        {guide.data.level} · {guide.data.pages} pages
      </div>

      <h1 class="display text-espresso leading-[1.02] text-5xl sm:text-7xl md:text-[5.2rem] mb-8">
        {guide.data.title}
      </h1>

      <p class="lede max-w-2xl mx-auto">
        {guide.data.subtitle}
      </p>
    </div>

    <div class="rule-centre text-espresso/30 my-14">
      <svg width="120" height="8" aria-hidden="true"><use href="#diamond-ornament"/></svg>
    </div>

    <div class="card-quiet p-9 sm:p-12 mb-14">
      <p class="font-serif italic font-light text-espresso/85 leading-relaxed text-xl mb-9">
        {guide.data.excerpt}
      </p>
      <div class="flex flex-wrap gap-5 items-center">
        <a href={guide.data.pdf} download class="btn-espresso">
          Download · free PDF
          <svg width="12" height="12" aria-hidden="true"><use href="#arrow-down"/></svg>
        </a>
        <a href={guide.data.pdf} class="link-quiet" target="_blank" rel="noopener">Preview in browser</a>
      </div>
    </div>

    <div class="prose-body prose-guide text-espresso/85 leading-relaxed">
      <Content />
    </div>
  </section>

  <section class="bg-bone-soft/50 border-t border-espresso/10 mt-20">
    <div class="max-w-3xl mx-auto px-6 sm:px-10 py-16 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-8">
      <div>
        <div class="label-wide text-espresso/55 mb-3">Next in the library</div>
        <a href={`/guides/${next.data.slug}/`} class="display text-3xl sm:text-4xl text-espresso hover:text-clay-deep transition-colors block">
          {next.data.title}
          <svg width="14" height="14" aria-hidden="true" class="inline-block ml-2 -mt-1 text-espresso/55"><use href="#arrow-right"/></svg>
        </a>
        <p class="font-serif italic font-light text-espresso/65 mt-2 text-lg">{next.data.subtitle}</p>
      </div>
      <a href="/guides/" class="btn-outline shrink-0">All five guides</a>
    </div>
  </section>
</Base>
