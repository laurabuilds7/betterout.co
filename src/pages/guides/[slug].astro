---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((g) => ({ params: { slug: g.data.slug }, props: { guide: g } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const all = (await getCollection("guides")).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((g) => g.data.slug === guide.data.slug);
const next = all[(idx + 1) % all.length];

// each guide page opens in its own card colour (soft, readable tint)
const heroTintBySlug: Record<string, string> = {
  "steady": "#F1EBDC",
  "kitchen-apothecary": "#E4EFE0",
  "nourished-littles": "#EDF1E6",
  "the-method": "#F1E7DA",
  "low-tox-living": "#E8EFDF",
  "roots": "#F2E8DC",
};
const heroBg = heroTintBySlug[guide.data.slug] ?? "#EDF1E6";
---
<Base title={guide.data.title} description={guide.data.subtitle}>

  <!-- coloured hero, in this guide's own colour -->
  <section class="relative" style={`background-color:${heroBg};`}>
    <div class="max-w-3xl mx-auto px-6 sm:px-10 pt-12 sm:pt-16 pb-16 sm:pb-20">
      <a href="/guides/" class="label text-matcha hover:text-forest transition-colors inline-flex items-center gap-2.5 mb-12">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Free guides
      </a>

      <div class="text-center">
        <div class="label-wide text-matcha mb-6">
          {guide.data.level}{guide.data.comingSoon ? " · coming soon" : ` · ${guide.data.pages} pages`}
        </div>

        <h1 class="display text-cocoa leading-[1.02] text-5xl sm:text-7xl md:text-[5rem] mb-8">
          {guide.data.title}
        </h1>

        <p class="lede max-w-2xl mx-auto">
          {guide.data.subtitle}
        </p>
      </div>
    </div>
  </section>

  <!-- download + content -->
  <section class="max-w-3xl mx-auto px-6 sm:px-10 pt-14 pb-8">
    <div class="rounded-[22px] p-8 sm:p-11 mb-14" style="background-color:#E4EEE1;">
      <p class="lede mb-9" style="color: color-mix(in srgb, var(--color-cocoa) 85%, transparent);">
        {guide.data.excerpt}
      </p>
      <div class="flex flex-wrap gap-5 items-center">
        {guide.data.comingSoon ? (
          <span class="label text-cocoa/60">The full guide is being written — check back soon.</span>
        ) : (
          <a href={guide.data.pdf} download data-guide-download class="btn-bright">
            Download · free PDF
            <svg width="12" height="12" aria-hidden="true"><use href="#arrow-down"/></svg>
          </a>
        )}
      </div>
    </div>

    <div class="prose-body prose-guide text-espresso/85 leading-relaxed">
      <Content />
    </div>
  </section>

  <!-- next guide -->
  <section class="border-t border-espresso/10" style="background-color:#EDF1E6;">
    <div class="max-w-3xl mx-auto px-6 sm:px-10 py-16 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-8">
      <div>
        <div class="label-wide text-matcha mb-3">Next guide</div>
        <a href={`/guides/${next.data.slug}/`} class="display text-3xl sm:text-4xl text-forest hover:text-matcha transition-colors block">
          {next.data.title}
          <svg width="14" height="14" aria-hidden="true" class="inline-block ml-2 -mt-1 text-matcha"><use href="#arrow-right"/></svg>
        </a>
        <p class="prose-body italic text-espresso/65 mt-2 text-lg">{next.data.subtitle}</p>
      </div>
      <a href="/guides/" class="btn-outline shrink-0">All guides</a>
    </div>
  </section>
</Base>
