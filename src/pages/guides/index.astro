---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import GuideCard from "../../components/GuideCard.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order
);
const total = guides.reduce((n, g) => n + g.data.pages, 0);
---
<Base title="The Library" description="Five free guides from Laura, founder of Better Out Co. — on steady energy, herbs as medicine, low-tox living, nourishing children, and deep healing.">
  <section class="max-w-4xl mx-auto px-5 sm:px-8 pt-16 sm:pt-24 pb-10">
    <div class="label text-kraft mb-4">The library — free, always</div>
    <h1 class="display text-5xl sm:text-6xl text-coffee leading-[1.02] mb-7">
      Five little guides.
    </h1>
    <p class="prose-body italic text-coffee/80 max-w-2xl">
      {total} pages of plain-language wellness — anti-hype, anti-overwhelm. Written from a kitchen in Cape Town. Start anywhere; most people begin with Steady.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-5 sm:px-8 pb-20 space-y-5">
    {guides.map((g) => (
      <GuideCard
        title={g.data.title}
        subtitle={g.data.subtitle}
        pages={g.data.pages}
        pdf={g.data.pdf}
        slug={g.data.slug}
        level={g.data.level}
        excerpt={g.data.excerpt}
        variant="feature"
      />
    ))}
  </section>
</Base>
