---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import GuideCard from "../../components/GuideCard.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order
);
const total = guides.reduce((n, g) => n + g.data.pages, 0);
---
<Base title="The Library" description="Five complimentary guides from Laura, founder of Better Out Co. — on steady energy, herbs as medicine, low-tox living, nourishing children, and deep healing.">

  <section class="relative">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 pt-24 sm:pt-32 pb-16 text-center">
      <div class="label-wide text-espresso/55 mb-10">The Library — complimentary, always</div>
      <h1 class="display text-espresso leading-[1.02] text-[2.85rem] sm:text-7xl md:text-[6rem]">
        Five quiet<br/>
        <span class="display-italic text-clay">guides.</span>
      </h1>
      <p class="mt-12 lede max-w-2xl mx-auto">
        {total} pages of plain-language wellness — anti-hype, anti-overwhelm. Written from a kitchen in Cape Town. Begin anywhere; most begin with <a href="/guides/steady/" class="underline decoration-clay/50 underline-offset-[6px] hover:text-clay-deep transition-colors">Steady</a>.
      </p>
      <div class="rule-centre text-espresso/30 mt-14">
        <svg width="120" height="8" aria-hidden="true"><use href="#diamond-ornament"/></svg>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 sm:px-10 py-16 sm:py-20 space-y-6">
    {guides.map((g, i) => (
      <GuideCard
        title={g.data.title}
        subtitle={g.data.subtitle}
        pages={g.data.pages}
        pdf={g.data.pdf}
        slug={g.data.slug}
        level={g.data.level}
        excerpt={g.data.excerpt}
        variant="feature"
        index={i}
      />
    ))}
  </section>
</Base>
