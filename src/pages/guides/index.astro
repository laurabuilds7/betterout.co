---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import GuideCard from "../../components/GuideCard.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order
);
const total = guides.reduce((n, g) => n + g.data.pages, 0);

const toneBySlug: Record<string, "sagelight" | "sage" | "moss" | "sand" | "nude" | "brown"> = {
  "the-method": "brown",
  "kitchen-apothecary": "moss",
  "low-tox-living": "sage",
  "steady": "sand",
  "nourished-littles": "sagelight",
  "roots": "nude",
};
---
<Base title="Free Guides" description="Free wellbeing guides from Laura, founder of Better Out Co. — steady energy, herbs, low-tox living, nourishing children, deep healing, and the step-by-step coffee enema method.">

  <section class="relative">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 pt-24 sm:pt-28 pb-12 text-center">
      <div class="label-wide text-matcha mb-8">Free Guides — always</div>
      <h1 class="display text-forest leading-[1.02] text-[3rem] sm:text-7xl md:text-[6rem]">
        Better <span class="text-matcha">starts here.</span>
      </h1>
      <p class="mt-10 lede max-w-2xl mx-auto">
        {total}+ pages of plain-language, no-hype wellbeing — written by hand in Cape Town. Yours free. No email, no catch. Begin anywhere; most begin with <a href="/guides/steady/" class="underline decoration-sage/50 underline-offset-[6px] hover:text-matcha transition-colors">Steady</a>.
      </p>
      <div class="rule-centre text-matcha/40 mt-12">
        <svg width="120" height="8" aria-hidden="true"><use href="#diamond-ornament"/></svg>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 sm:px-10 pb-20 sm:pb-28">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 items-stretch">
      {guides.map((g) => (
        <GuideCard
          title={g.data.title}
          subtitle={g.data.subtitle}
          pages={g.data.pages}
          pdf={g.data.pdf}
          slug={g.data.slug}
          level={g.data.level}
          tone={toneBySlug[g.data.slug] ?? "sagelight"}
          comingSoon={g.data.comingSoon}
        />
      ))}
    </div>
  </section>
</Base>
